# ===== frpc 实例运行参数（Agent 侧用于运行 frpc 容器）=====
FRP_IMAGE=ghcr.io/fatedier/frpc:v0.68.1
FRPC_MEMORY_LIMIT=128m
FRPC_CPU_LIMIT=0.25
TZ=Asia/Shanghai

# ===== 角色 =====
# 反转模型只有两种角色（all 模式已取消）：
#   console —— 主控：前端 + /api/* + /ws/agent（接受 Agent 出站连接）
#   agent   —— 执行端：出站连回主控 + 挂 docker.sock 管理本机 frpc 实例
# 主控自身若要跑 frpc 实例，在主控机另装一个 agent（见 docs/AGENT_INSTALL.md）。
FRPC_MULTI_ROLE=console

# ===== Console（主控）=====
WEBUI_USERNAME=admin
WEBUI_PASSWORD=change-this-password
WEBUI_JWT_SECRET=
# 默认只允许同源本机访问前端。若通过域名或反向代理访问 Console，按逗号分隔填写允许来源，
# 例如：WEBUI_CORS_ORIGINS=https://frpc.example.com
WEBUI_CORS_ORIGINS=
DATABASE_PATH=/data/console.db
CONSOLE_DATA_VOLUME=frpc-multi-console_console-data
CONSOLE_HOST=127.0.0.1
CONSOLE_PORT=8081
# 主控对 Agent 暴露的可达地址 host:port，写进一键安装命令。例如 frpc.example.com:8081 或 1.2.3.4:8081。
# 留空时安装命令里用占位符，需手填。
CONSOLE_PUBLIC_HOST=
# 主控在 TLS 反代后时设为 true，安装命令会用 wss/https。
CONSOLE_TLS=false
# 一键安装拉取的 Agent 镜像（GHCR）。默认用仓库发布的镜像，一般无需设置；
# 留空/注释即沿用 compose 内置默认 ghcr.io/354770288/frpc-multi:latest。
# 仅当你 fork 了仓库、用自己的 GHCR 镜像时才取消注释并改成你的路径。
# AGENT_IMAGE=ghcr.io/354770288/frpc-multi:latest
# 可选：install.sh 下载地址，配置后一键命令会 curl 它。
AGENT_INSTALL_URL=

# ===== Agent（执行端，通常由一键安装命令注入，手动部署时才需填）=====
# 主控可达地址 host:port（与 CONSOLE_PUBLIC_HOST 一致）。
AGENT_SERVER=
# 节点身份与出站鉴权密钥，由 Console 新建节点时生成。
AGENT_UUID=
AGENT_SECRET=
# 主控在 TLS 反代后时设为 true（使用 wss）。
AGENT_TLS=false
